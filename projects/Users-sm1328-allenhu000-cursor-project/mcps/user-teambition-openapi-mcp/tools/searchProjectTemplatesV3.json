{
  "name": "searchProjectTemplatesV3",
  "description": "搜索企业项目模板",
  "arguments": {
    "type": "object",
    "properties": {
      "ptIds": {
        "type": "string",
        "description": "模板ID集合，逗号组合"
      },
      "projectIds": {
        "type": "string",
        "description": "模板对应的项目ID集合，逗号组合，对应项目模型上的 sourceId"
      },
      "includeDraft": {
        "type": "boolean",
        "description": "是否包含草稿态模板"
      },
      "q": {
        "type": "string",
        "description": "模糊查询名字"
      },
      "pageSize": {
        "type": "number",
        "description": "分页长度"
      },
      "pageToken": {
        "type": "string",
        "description": "分页标"
      }
    },
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}