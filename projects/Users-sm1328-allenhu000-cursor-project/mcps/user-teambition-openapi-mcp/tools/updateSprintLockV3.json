{
  "name": "updateSprintLockV3",
  "description": "迭代锁定",
  "arguments": {
    "type": "object",
    "properties": {
      "projectId": {
        "type": "string",
        "description": "项目 ID"
      },
      "sprintId": {
        "type": "string",
        "description": "迭代ID"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "isLocked": {
            "type": "boolean",
            "description": "是否锁定迭代"
          },
          "disableMoveIn": {
            "type": "boolean",
            "description": "是否禁止移入迭代"
          },
          "disableMoveOut": {
            "type": "boolean",
            "description": "是否禁止移出迭代"
          },
          "disableMoveInSfcs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "允许移入迭代的任务类型ID"
          },
          "disableMoveOutSfcs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "允许移出迭代的任务类型ID"
          }
        },
        "additionalProperties": false,
        "description": "The JSON request body."
      }
    },
    "required": [
      "projectId",
      "sprintId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}