{
  "name": "createTaskCommentV3",
  "description": "评论任务",
  "arguments": {
    "type": "object",
    "properties": {
      "taskId": {
        "type": "string",
        "description": "任务ID"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "评论内容"
          },
          "renderMode": {
            "type": "string",
            "description": "评论内容 原文 还是以 `markdown` 等格式. 默认是原文输出"
          },
          "mentionUserIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 30,
            "description": "评论 at 成员列表, 单次 at 上限30"
          }
        },
        "additionalProperties": false,
        "description": "The JSON request body."
      }
    },
    "required": [
      "taskId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}