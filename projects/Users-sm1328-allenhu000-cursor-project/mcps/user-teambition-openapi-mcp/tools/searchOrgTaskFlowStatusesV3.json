{
  "name": "searchOrgTaskFlowStatusesV3",
  "description": "搜索企业工作流状态",
  "arguments": {
    "type": "object",
    "properties": {
      "tfIds": {
        "type": "string",
        "description": "工作流ID集合，逗号组合"
      },
      "q": {
        "type": "string",
        "description": "模糊查询工作流名字"
      },
      "pageSize": {
        "type": "number",
        "description": "每页工作流长度"
      },
      "pageToken": {
        "type": "string",
        "description": "分页标"
      }
    },
    "required": [
      "tfIds"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}