{
  "name": "listProjectMembersV3",
  "description": "获取项目成员列表",
  "arguments": {
    "type": "object",
    "properties": {
      "projectId": {
        "type": "string",
        "description": "项目ID"
      },
      "userIds": {
        "type": "string",
        "description": "如果传递，仅查询这些用户ID， 用逗号组合"
      },
      "projectRoleId": {
        "type": "string",
        "description": "项目角色ID，仅查询拥有该角色的成员，并且仅支持单个角色查询"
      },
      "limit": {
        "type": "number",
        "description": "每一页数量"
      },
      "skip": {
        "type": "number",
        "description": "分页"
      },
      "pageSize": {
        "type": "number",
        "description": "分页大小"
      },
      "pageToken": {
        "type": "string",
        "description": "分页标"
      }
    },
    "required": [
      "projectId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}