{
  "name": "updateTaskPriorityV3",
  "description": "更新任务优先级",
  "arguments": {
    "type": "object",
    "properties": {
      "taskId": {
        "type": "string",
        "description": "任务ID"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "priority": {
            "type": "number",
            "description": "优先级"
          },
          "priorityName": {
            "type": "string",
            "description": "优先级名称（取通过优先级名称名匹配到的第一个优先级，与priority同时传入时优先用priority）"
          }
        },
        "additionalProperties": false,
        "description": "更新任务优先级请求"
      }
    },
    "required": [
      "taskId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}