{
  "name": "createProjectFromTemplateV3",
  "description": "从模板创建项目",
  "arguments": {
    "type": "object",
    "properties": {
      "organizationId": {
        "type": "string",
        "description": "企业ID, 如果提供`x-tenant-id`, query中不是必须的, 如果提供必须和`x-tenant-id`一致"
      },
      "waitForCompletion": {
        "type": "boolean",
        "description": "是否等待项目下资源全部复制完成"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "项目名称"
          },
          "templateId": {
            "type": "string",
            "description": "模板ID"
          },
          "templateName": {
            "type": "string",
            "description": "模板名称（取通过模版名匹配到的第一个模版，templateId、templateName至少传一个，与templateId同时传入时优先用templateId）"
          },
          "isTemplate": {
            "type": "boolean",
            "description": "是否为模板项目，默认为 false"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "project",
              "organization"
            ],
            "description": "项目可见性"
          },
          "programId": {
            "type": "string",
            "description": "项目所属项目集ID"
          },
          "programName": {
            "type": "string",
            "description": "项目所属项目集名称（取通过项目集名匹配到的第一个项目集，与programId同时传入时优先用programId）"
          },
          "description": {
            "type": "string",
            "description": "项目描述"
          },
          "startDate": {
            "type": "string",
            "format": "date-time",
            "description": "项目开始时间"
          },
          "endDate": {
            "type": "string",
            "format": "date-time",
            "description": "项目结束时间"
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false,
        "description": "从模板创建项目请求"
      }
    },
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}