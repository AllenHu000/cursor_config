{
  "name": "updateProjectGroupMemberPermissionV3",
  "description": "更新项目分组成员权限",
  "arguments": {
    "type": "object",
    "properties": {
      "projectTagId": {
        "type": "string",
        "description": "项目分组 ID"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "subjectType": {
            "type": "string",
            "description": "项目分组成员类型，如 organizationMember, organizationTeam, organizationGroup"
          },
          "subjectId": {
            "type": "string",
            "description": "当 subjectType 为 organizationMember 时, 该值为 userId；当 subjectType 为 organizationTeam 时, 该值为 teamId；当 subjectType 为 organizationGroup 时, 该值为 groupId；"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "权限项"
            },
            "description": "权限项列表，覆盖式更新"
          }
        },
        "required": [
          "subjectType",
          "subjectId",
          "permissions"
        ],
        "additionalProperties": false,
        "description": "The JSON request body."
      }
    },
    "required": [
      "projectTagId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}