{
  "name": "getCalendarView",
  "description": "查询日程视图，按时间范围获取日程列表",
  "arguments": {
    "type": "object",
    "properties": {
      "unionId": {
        "type": "string",
        "description": "用户的unionId"
      },
      "calendarId": {
        "type": "string",
        "description": "日程所属的日历ID，统一为primary"
      },
      "timeMin": {
        "type": "string",
        "description": "查询的起始时间，格式为ISO-8601的date-time格式。"
      },
      "timeMax": {
        "type": "string",
        "description": "查询的结束时间，格式为ISO-8601的date-time格式。"
      },
      "maxAttendees": {
        "type": "number",
        "description": "返回的参与者列表的最大数量"
      },
      "maxResults": {
        "type": "number",
        "description": "最大返回数量"
      },
      "nextToken": {
        "type": "string",
        "description": "分页标记"
      }
    },
    "required": [
      "unionId",
      "calendarId",
      "timeMin",
      "timeMax"
    ]
  }
}