{
  "name": "updateExecutorsTaskStatus",
  "description": "更新执行人待办状态",
  "arguments": {
    "type": "object",
    "properties": {
      "unionId": {
        "type": "string",
        "description": "待办所属用户UnionId"
      },
      "taskId": {
        "type": "string",
        "description": "待办ID"
      },
      "executorStatusList": {
        "type": "array",
        "description": "执行者状态列表，id需传用户的unionId，最大数量1000。",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "执行者unionId"
            },
            "isDone": {
              "type": "boolean",
              "description": "执行者完成状态"
            }
          },
          "required": [
            "id",
            "isDone"
          ]
        }
      }
    },
    "required": [
      "unionId",
      "taskId",
      "executorStatusList"
    ]
  }
}