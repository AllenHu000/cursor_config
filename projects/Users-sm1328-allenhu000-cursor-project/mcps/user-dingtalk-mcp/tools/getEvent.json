{
  "name": "getEvent",
  "description": "查询单个日程的详细信息",
  "arguments": {
    "type": "object",
    "properties": {
      "unionId": {
        "type": "string",
        "description": "日程组织者的unionId"
      },
      "calendarId": {
        "type": "string",
        "description": "日程所属的日历ID，统一为primary"
      },
      "eventId": {
        "type": "string",
        "description": "要查询的日程ID"
      },
      "maxAttendees": {
        "type": "number",
        "description": "返回的参与者列表的最大数量"
      }
    },
    "required": [
      "unionId",
      "calendarId",
      "eventId"
    ]
  }
}