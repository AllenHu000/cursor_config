{
  "name": "deleteEvent",
  "description": "删除指定的日程",
  "arguments": {
    "type": "object",
    "properties": {
      "unionId": {
        "type": "string",
        "description": "日程组织者的unionId"
      },
      "calendarId": {
        "type": "string",
        "description": "日程所属的日历ID，统一为primary"
      },
      "eventId": {
        "type": "string",
        "description": "要删除的日程ID"
      },
      "pushNotification": {
        "type": "boolean",
        "description": "是否发送弹窗提醒"
      }
    },
    "required": [
      "unionId",
      "calendarId",
      "eventId"
    ]
  }
}