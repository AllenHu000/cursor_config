{
  "name": "get-message",
  "description": "获取单封邮件的完整正文（用于查看内容或自行提取验证码）。",
  "arguments": {
    "type": "object",
    "properties": {
      "token": {
        "type": "string",
        "description": "create-inbox 返回的 token"
      },
      "messageId": {
        "type": "string",
        "description": "邮件 ID，来自 get-messages 返回的 id"
      }
    },
    "required": [
      "token",
      "messageId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}