{
  "name": "getAttendees",
  "description": "获取日程参与者列表",
  "arguments": {
    "type": "object",
    "properties": {
      "unionId": {
        "type": "string",
        "description": "日程创建者的unionId"
      },
      "calendarId": {
        "type": "string",
        "description": "日程所属的日历ID，统一为primary"
      },
      "eventId": {
        "type": "string",
        "description": "日程ID"
      },
      "maxResults": {
        "type": "number",
        "description": "最大返回数量，默认100，最大500"
      },
      "nextToken": {
        "type": "string",
        "description": "分页标记"
      }
    },
    "required": [
      "unionId",
      "calendarId",
      "eventId"
    ]
  }
}