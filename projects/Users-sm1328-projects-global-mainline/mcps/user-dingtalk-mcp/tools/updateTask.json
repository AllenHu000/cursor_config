{
  "name": "updateTask",
  "description": "更新待办",
  "arguments": {
    "type": "object",
    "properties": {
      "unionId": {
        "type": "string",
        "description": "用户UnionId"
      },
      "taskId": {
        "type": "string",
        "description": "待办ID"
      },
      "subject": {
        "type": "string",
        "description": "待办标题，最大长度1024"
      },
      "description": {
        "type": "string",
        "description": "待办备注，4096"
      },
      "done": {
        "type": "boolean",
        "description": "完成状态。true：已完成；false：未完成"
      },
      "dueTime": {
        "type": "number",
        "description": "待办截止时间，Unix时间戳，单位毫秒。"
      },
      "executorIds": {
        "type": "array",
        "description": "待办执行人的UnionId",
        "items": {
          "type": "string"
        }
      },
      "participantIds": {
        "type": "array",
        "description": "待办参与人的UnionId",
        "items": {
          "type": "string"
        }
      }
    },
    "required": [
      "unionId",
      "taskId",
      "subject"
    ]
  }
}