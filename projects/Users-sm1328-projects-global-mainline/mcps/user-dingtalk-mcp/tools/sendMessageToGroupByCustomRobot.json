{
  "name": "sendMessageToGroupByCustomRobot",
  "description": "使用群自定义机器人向指定群发送消息。 仅在用户明确要求“使用自定义机器人”或“通过自定义机器人发消息”时调用此工具。 注意：此工具只能用于向群（group）发送消息，不能用于单聊或个人用户。 如果用户未明确提及自定义机器人，请不要调用此工具。\n",
  "arguments": {
    "type": "object",
    "properties": {
      "markdown": {
        "type": "object",
        "description": "markdown消息",
        "properties": {
          "title": {
            "type": "string",
            "description": "消息标题。"
          },
          "text": {
            "type": "string",
            "description": "消息内容，markdown格式。"
          }
        }
      },
      "at": {
        "type": "object",
        "description": "AT群成员",
        "properties": {
          "isAtAll": {
            "type": "boolean",
            "description": "是否AT所有人，默认为false。"
          },
          "atUserIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "被AT的群成员userId。"
          }
        }
      }
    },
    "required": []
  }
}