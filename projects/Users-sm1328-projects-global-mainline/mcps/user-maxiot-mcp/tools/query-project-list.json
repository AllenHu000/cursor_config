{
  "name": "query-project-list",
  "description": "查询 MaxIoT 平台的项目列表，支持关键字搜索、分页、按项目类型过滤",
  "arguments": {
    "type": "object",
    "properties": {
      "keyword": {
        "type": "string",
        "description": "搜索关键字"
      },
      "pageNum": {
        "type": "number",
        "default": 1,
        "description": "页码"
      },
      "pageSize": {
        "type": "number",
        "default": 10,
        "description": "每页数量"
      },
      "tenantCode": {
        "type": "string",
        "description": "租户编码，不传使用默认值"
      },
      "joinType": {
        "type": "number",
        "default": 1,
        "description": "1=我参与的, 0=全部"
      },
      "projectTypeList": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [
          "application",
          "component"
        ],
        "description": "项目类型，如 application / component"
      }
    },
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}