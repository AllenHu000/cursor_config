{
  "name": "searchTaskflowsV3",
  "description": "搜索项目工作流",
  "arguments": {
    "type": "object",
    "properties": {
      "projectId": {
        "type": "string",
        "description": "项目ID"
      },
      "q": {
        "type": "string",
        "description": "模糊查询工作流名字"
      },
      "pageSize": {
        "type": "number",
        "description": "每页长度"
      },
      "pageToken": {
        "type": "string",
        "description": "分页标"
      },
      "tfIds": {
        "type": "string",
        "description": "工作流ID集合，逗号组合"
      }
    },
    "required": [
      "projectId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}