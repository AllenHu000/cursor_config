{
  "name": "updateProjectV3",
  "description": "更新项目",
  "arguments": {
    "type": "object",
    "properties": {
      "projectId": {
        "type": "string",
        "description": "项目ID"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "项目名称"
          },
          "description": {
            "type": "string",
            "description": "项目描述"
          },
          "logo": {
            "type": "string",
            "description": "项目LOGO的url"
          },
          "visibility": {
            "type": "string",
            "description": "项目可见行，project | organization"
          },
          "startDate": {
            "type": "string",
            "format": "date-time",
            "description": "项目启动时间, 空字符串 代表清空"
          },
          "endDate": {
            "type": "string",
            "format": "date-time",
            "description": "项目结束时间, 空字符串 代表清空"
          }
        },
        "additionalProperties": false,
        "description": "The JSON request body."
      }
    },
    "required": [
      "projectId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}