{
  "name": "searchProjectTasksV3",
  "description": "查询项目任务",
  "arguments": {
    "type": "object",
    "properties": {
      "projectId": {
        "type": "string",
        "description": "项目ID"
      },
      "q": {
        "type": "string",
        "description": "查询语句 参考[TQL查询文档](doc.fullPath=/tql-doc)"
      },
      "includeArchived": {
        "type": "boolean",
        "description": "是否包含已归档任务, 默认 false"
      },
      "pageToken": {
        "type": "string",
        "description": "分页标"
      },
      "pageSize": {
        "type": "number",
        "description": "每页任务数量，默认为10"
      }
    },
    "required": [
      "projectId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}