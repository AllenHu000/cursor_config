{
  "name": "updateProjectGroupV3",
  "description": "修改项目分组",
  "arguments": {
    "type": "object",
    "properties": {
      "projectTagId": {
        "type": "string",
        "description": "项目分组 ID"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "visible": {
            "type": "string",
            "enum": [
              "organization",
              "involves"
            ],
            "description": "项目分组可见性，involves 私有项目分组, organization 公开项目分组"
          }
        },
        "additionalProperties": false,
        "description": "The JSON request body."
      }
    },
    "required": [
      "projectTagId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}