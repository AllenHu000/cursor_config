{
  "name": "createTaskV3",
  "description": "创建任务",
  "arguments": {
    "type": "object",
    "properties": {
      "requestBody": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "description": "项目id"
          },
          "projectName": {
            "type": "string",
            "description": "项目名称（projectId、projectName，projectUniqueIdPrefix至少传一个，优先用projectId）"
          },
          "projectUniqueIdPrefix": {
            "type": "string",
            "description": "任务编号前缀，即项目编号（projectId、projectName，projectUniqueIdPrefix至少传一个，优先用projectId）"
          },
          "content": {
            "type": "string",
            "maxLength": 500,
            "description": "任务标题"
          },
          "executorId": {
            "type": "string",
            "description": "执行者id"
          },
          "involveMembers": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "参与者用户ID"
            },
            "description": "参与者用户ID列表"
          },
          "stageId": {
            "type": "string",
            "description": "任务列id"
          },
          "tasklistId": {
            "type": "string",
            "description": "任务组id"
          },
          "taskflowstatusId": {
            "type": "string",
            "description": "任务状态id"
          },
          "tfsName": {
            "type": "string",
            "description": "任务状态名称（取通过任务状态名匹配到的第一个任务状态，与taskflowstatusId同时传入时优先用taskflowstatusId）"
          },
          "startDate": {
            "type": "string",
            "format": "date-time",
            "description": "开始日期"
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "description": "截止日期"
          },
          "note": {
            "type": "string",
            "description": "任务备注"
          },
          "noteRenderMode": {
            "type": "string",
            "enum": [
              "markdown",
              "rtf"
            ],
            "description": "任务备注渲染模式, markdown, rtf, rtf就是富文本，富文本需要提交 rtfValueToken"
          },
          "noteRtfValueToken": {
            "type": "string",
            "description": "任务备注富文本内容，格式仅限从 rtf/render 接口中获取的 rtfValue"
          },
          "priority": {
            "type": "number",
            "description": "执行优先级"
          },
          "priorityName": {
            "type": "string",
            "description": "执行优先级名称（取通过优先级名称名匹配到的第一个优先级，与priority同时传入时优先用priority）"
          },
          "parentTaskId": {
            "type": "string",
            "description": "父任务id"
          },
          "progress": {
            "type": "number",
            "description": "进度"
          },
          "visible": {
            "type": "string",
            "description": "任务的可见性规则 involves | members"
          },
          "sprintId": {
            "type": "string",
            "description": "迭代id"
          },
          "tagIds": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "标签id"
            },
            "description": "标签id列表"
          },
          "tagNames": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "标签名称"
            },
            "description": "标签名称列表（列表中标签取通过标签名匹配到的第一个标签，与tagIds同时传入时优先用tagIds）"
          },
          "storyPoint": {
            "type": "string",
            "description": "任务故事点"
          },
          "scenariofieldconfigId": {
            "type": "string",
            "description": "任务类型id"
          },
          "scenariofieldconfigAlias": {
            "type": "string",
            "description": "任务类型别名(如果提供任务类型id 则忽略)"
          },
          "reminders": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "labels": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "description": "任务提醒 [source:task]"
                  }
                },
                "receivers": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "description": "接受者 [user/userId, role/executor, role/involver, role/creator]"
                  }
                },
                "rule": {
                  "type": "string",
                  "description": "提醒规则 [custom/具体时间, dueDate/P0D, startDate/-PT5M, circle/DTSTART:20220209T173500Z\\nRRULE:FREQ=DAILY;COUNT=30;INTERVAL=1;WKST=MO]，注意：循环提醒 rrule 规则 join('\\n')"
                }
              },
              "additionalProperties": false
            },
            "maxItems": 9
          },
          "customfields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "cfId": {
                  "type": "string",
                  "description": "自定义字段值ID"
                },
                "customfieldName": {
                  "type": "string",
                  "description": "自定义字段名字(如果提供自定义字段值ID则忽略)"
                },
                "customfieldAlias": {
                  "type": "string",
                  "description": "自定义字段别名(如果提供自定义字段值ID或自定义字段名字则忽略)"
                },
                "value": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "字段值ID。对于成员类型的字段, 将使用这个值用于统计, 自动化触发条件。 可以利用通讯录接口响应中的 userId 字段"
                      },
                      "title": {
                        "type": "string",
                        "description": "自定义字段值内容, 用于字段渲染, 必填。对于成员字段, 请保持和 `字段值ID` 内容一致，系统将通过通讯录中翻译成真实用户名称"
                      },
                      "description": {
                        "type": "string"
                      },
                      "thumbUrl": {
                        "type": "string"
                      },
                      "url": {
                        "type": "string"
                      },
                      "meta": {
                        "type": "string",
                        "description": "字段值元信息(json格式)"
                      },
                      "metaString": {
                        "type": "string",
                        "description": "字段值元信息(json格式)。\n- 对于文件字段，需要在 metaString 中填写 `\\\"fileToken\\\":\\\"xxx\\\"`，可调用创建文件上传凭证接口获得\n"
                      }
                    },
                    "additionalProperties": false,
                    "description": "自定义字段值内容"
                  },
                  "description": "自定义字段值列表"
                }
              },
              "additionalProperties": false,
              "description": "自定义字段值"
            },
            "description": "自定义字段值列表"
          }
        },
        "required": [
          "content"
        ],
        "additionalProperties": false,
        "description": "The JSON request body."
      }
    },
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}