{
  "name": "updateTaskTagsV3",
  "description": "更新任务标签",
  "arguments": {
    "type": "object",
    "properties": {
      "taskId": {
        "type": "string",
        "description": "任务ID"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "tagIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "替换的标签ID集合"
          },
          "tagNames": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "替换的标签名称列表（列表中标签取通过标签名匹配到的第一个标签，与tagIds同时传入时优先用tagIds）"
          },
          "delTagIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "删除的标签ID集合"
          },
          "delTagNames": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "删除的标签名称列表（列表中标签取通过标签名匹配到的第一个标签，与tagIds同时传入时优先用delTagIds）"
          },
          "addTagIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "新增的标签ID集合"
          },
          "addTagNames": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "新增的标签名称列表（列表中标签取通过标签名匹配到的第一个标签，与tagIds同时传入时优先用addTagIds）"
          }
        },
        "additionalProperties": false,
        "description": "The JSON request body."
      }
    },
    "required": [
      "taskId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}